# LLM Provider: "gemini" or "openrouter"
LLM_PROVIDER=openrouter

# OpenRouter configuration (when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Gemini configuration (when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key_here

# LLM model override (optional — leaves blank for default)
# LLM_MODEL=

# AWS S3 (optional — for clip backup/gallery)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BUCKET=your-public-bucket-name

# Concurrency limits
# MAX_CONCURRENT_JOBS=5
# BATCH_CONCURRENCY=3

# YouTube cookies (optional — paste Netscape-format cookies to bypass bot detection)
# YOUTUBE_COOKIES=...

# Auth (optional — set to enable API key auth)
# API_AUTH_KEY=your_api_auth_key_here

# JWT secret (optional — auto-generated if not set)
# JWT_SECRET=your_jwt_secret_here

# Admin password (optional — auto-generated random if not set)
# ADMIN_PASSWORD=your_admin_password_here

# CORS origins (default: localhost:5173,localhost:5175)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# Disable YouTube URL processing
# DISABLE_YOUTUBE_URL=true

# Render service URL (default: http://renderer:3100 in Docker)
# RENDER_SERVICE_URL=http://localhost:3100

# Redis (optional — falls back to in-memory queue)
# REDIS_URL=redis://localhost:6379

# Whisper configuration
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
